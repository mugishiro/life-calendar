{
  "expo": {
    "name": "Life Calendar",
    "slug": "life-calendar",
    "scheme": "lifecalendar",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4efe6"
    },
    "ios": {
      "bundleIdentifier": "com.mugishiro.lifecalendar",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f4efe6"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "baseUrl": "/life-calendar"
    },
    "plugins": [
      "expo-dev-client",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "415a2ff0-1a9b-4a68-84b7-f89227ab1645"
      }
    }
  }
}
